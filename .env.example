# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OpenAI API for Image Generation/Editing
OPENAI_API_KEY=your_openai_api_key_here

# Replicate API for Image Upscaling
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Cloudinary for Image Storage
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
CLOUDINARY_UPLOAD_PRESET=modern_mosaics

# Gelato API for Print Services
GELATO_API_KEY=your_gelato_api_key_here
GELATO_PARTNER_ID=your_gelato_partner_id_here
