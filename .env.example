# Firebase Authentication
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# OpenAI API for Image Generation/Editing
OPENAI_API_KEY=your_openai_api_key_here

# Cloudinary for Image Storage and Processing
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
CLOUDINARY_UPLOAD_PRESET=modern_mosaics

# Gelato API for Print Services
GELATO_API_KEY=your_gelato_api_key_here
GELATO_PARTNER_ID=your_gelato_partner_id_here

# Stripe Payment Processing
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret
# Get this after creating a webhook endpoint at https://dashboard.stripe.com/webhooks
# The endpoint should be: https://yourdomain.com/api/checkout/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Optional: Stripe configuration
STRIPE_SUCCESS_URL=https://yourdomain.com/order/confirmation
STRIPE_CANCEL_URL=https://yourdomain.com/order

# Optional: Comma-separated admin emails allowed to access debug APIs in non-development environments
DEBUG_ADMIN_EMAILS=admin@example.com

# Distributed rate limiting
# auto = Redis when REDIS_URL is configured, otherwise in-memory for local/dev only
RATE_LIMIT_STORE=auto
REDIS_URL=redis://localhost:6379
RATE_LIMIT_KEY_PREFIX=modern-mosaics:ratelimit

# Keep this disabled in all deployed environments.
# Direct customer fulfillment must only happen through Stripe checkout + webhook.
ENABLE_DIRECT_ORDER_CREATE=false
