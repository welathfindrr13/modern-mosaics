rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Images subcollection - users can manage their own images
      match /images/{imageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Orders subcollection - users can read their own orders, but only server can write
      match /orders/{orderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only server-side operations can write orders
        
        // Order status history - users can read, only server can write
        match /statusHistory/{historyId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow write: if false; // Only server-side operations can write
        }
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
